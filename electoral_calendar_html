<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Electoral Calendar</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-size: 13px;
    background: #fff;
    color: #222;
    padding: 0;
  }

  .ec-header {
    background: #1a2236;
    color: #fff;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 11px 18px;
  }
  .ec-header span {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .ec-header a {
    color: #f0b429;
    font-size: 12px;
    text-decoration: none;
  }

  .table-wrap { overflow-x: auto; }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }

  thead th {
    background: #f7f7f5;
    color: #666;
    font-size: 12px;
    font-weight: 600;
    padding: 9px 10px;
    text-align: left;
    border-bottom: 1px solid #ddd;
    white-space: nowrap;
  }

  tbody td {
    padding: 9px 10px;
    border-bottom: 1px solid #ebebeb;
    vertical-align: middle;
    color: #222;
  }

  tbody tr:last-child td { border-bottom: none; }
  tbody tr:hover td { background: #fafafa; }

  .badge {
    display: inline-block;
    padding: 3px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 500;
    color: #fff;
    white-space: nowrap;
  }

  .type-parliament   { background: #3a7bd5; }
  .type-referendum   { background: #7c3aed; }
  .type-regional     { background: #16a34a; }
  .type-presidential { background: #ea580c; }
  .type-other        { background: #64748b; }

  .status-confirmed   { color: #222; }
  .status-unconfirmed { color: #999; }

  .credit { font-size: 11px; color: #aaa; padding: 8px 10px; }
  .credit a { color: #3a7bd5; text-decoration: none; }

  #loading { padding: 2rem; text-align: center; color: #888; font-size: 13px; }
  #error   { padding: 2rem; text-align: center; color: #c00; font-size: 13px; display: none; }
</style>
</head>
<body>

<div class="ec-header">
  <span>Electoral Calendar</span>
  <a href="https://docs.google.com/spreadsheets/d/1Wdx_eDbVv2XaMlSoYnzauLch_47xWHjP181iVV8QIrM/" target="_blank">Full Calendar →</a>
</div>

<div id="loading">Loading…</div>
<div id="error">Could not load data. Make sure the Google Sheet is published to the web as CSV.</div>

<div class="table-wrap" id="table-wrap" style="display:none;">
  <table id="ec-table">
    <thead id="ec-head"></thead>
    <tbody id="ec-body"></tbody>
  </table>
  <p class="credit">Data from <a href="https://docs.google.com/spreadsheets/d/1Wdx_eDbVv2XaMlSoYnzauLch_47xWHjP181iVV8QIrM/" target="_blank">Google Sheets</a></p>
</div>

<script>
  const SHEET_ID = "1Wdx_eDbVv2XaMlSoYnzauLch_47xWHjP181iVV8QIrM";
  const GID      = "1530371858";
  const CSV_URL  = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/export?format=csv&gid=${GID}`;

  // ── COLUMN HEADER KEYWORDS ──────────────────────────────────────────────────
  // These are matched against your actual sheet headers (case-insensitive).
  // Edit if your column names differ.
  const COUNTRY_KEYWORDS = ["country"];
  const TYPE_KEYWORDS    = ["type"];
  const STATUS_KEYWORDS  = ["status", "date status"];

  // ── FLAGS ───────────────────────────────────────────────────────────────────
  // Maps lowercase country name (or common abbreviation) → flag emoji
  const FLAGS = {
    "albania": "🇦🇱",
    "andorra": "🇦🇩",
    "armenia": "🇦🇲",
    "austria": "🇦🇹",
    "azerbaijan": "🇦🇿",
    "belarus": "🇧🇾",
    "belgium": "🇧🇪",
    "bosnia": "🇧🇦",
    "bosnia and herzegovina": "🇧🇦",
    "bulgaria": "🇧🇬",
    "croatia": "🇭🇷",
    "cyprus": "🇨🇾",
    "czech republic": "🇨🇿",
    "czechia": "🇨🇿",
    "denmark": "🇩🇰",
    "estonia": "🇪🇪",
    "finland": "🇫🇮",
    "france": "🇫🇷",
    "georgia": "🇬🇪",
    "germany": "🇩🇪",
    "greece": "🇬🇷",
    "hungary": "🇭🇺",
    "iceland": "🇮🇸",
    "ireland": "🇮🇪",
    "italy": "🇮🇹",
    "kosovo": "🇽🇰",
    "latvia": "🇱🇻",
    "liechtenstein": "🇱🇮",
    "lithuania": "🇱🇹",
    "luxembourg": "🇱🇺",
    "malta": "🇲🇹",
    "moldova": "🇲🇩",
    "monaco": "🇲🇨",
    "montenegro": "🇲🇪",
    "netherlands": "🇳🇱",
    "north macedonia": "🇲🇰",
    "norway": "🇳🇴",
    "poland": "🇵🇱",
    "portugal": "🇵🇹",
    "romania": "🇷🇴",
    "russia": "🇷🇺",
    "san marino": "🇸🇲",
    "serbia": "🇷🇸",
    "slovakia": "🇸🇰",
    "slovenia": "🇸🇮",
    "spain": "🇪🇸",
    "sweden": "🇸🇪",
    "switzerland": "🇨🇭",
    "turkey": "🇹🇷",
    "ukraine": "🇺🇦",
    "united kingdom": "🇬🇧",
    "uk": "🇬🇧",
    "england": "🏴󠁧󠁢󠁥󠁮󠁧󠁿",
    "scotland": "🏴󠁧󠁢󠁳󠁣󠁴󠁿",
    "wales": "🏴󠁧󠁢󠁷󠁬󠁳󠁿",
  };

  function getFlag(country) {
    if (!country) return "";
    const key = country.toLowerCase().trim();
    // Exact match first
    if (FLAGS[key]) return FLAGS[key];
    // Partial match — e.g. "United Kingdom (England)" → still finds UK
    for (const [k, v] of Object.entries(FLAGS)) {
      if (key.includes(k) || k.includes(key)) return v;
    }
    return "";
  }

  // ── TYPE → BADGE CLASS ──────────────────────────────────────────────────────
  function typeClass(val) {
    const v = (val || "").toLowerCase();
    if (v.includes("parliament") || v.includes("lower house") || v.includes("upper house") || v.includes("by-election") || v.includes("legislative")) return "type-parliament";
    if (v.includes("referendum") || v.includes("initiative") || v.includes("plebiscite")) return "type-referendum";
    if (v.includes("regional") || v.includes("local") || v.includes("municipal") || v.includes("cantonal") || v.includes("provincial")) return "type-regional";
    if (v.includes("presidential") || v.includes("head of state") || v.includes("prime minister")) return "type-presidential";
    return "type-other";
  }

  function statusClass(val) {
    const v = (val || "").toLowerCase();
    return (v.includes("not") || v.includes("unconfirmed") || v.includes("tentative")) ? "status-unconfirmed" : "status-confirmed";
  }

  // ── CSV PARSER ──────────────────────────────────────────────────────────────
  function parseCSV(text) {
    const rows = [];
    let row = [], field = "", inQ = false;
    for (let i = 0; i < text.length; i++) {
      const c = text[i], next = text[i + 1];
      if (inQ) {
        if (c === '"' && next === '"') { field += '"'; i++; }
        else if (c === '"') { inQ = false; }
        else { field += c; }
      } else {
        if (c === '"') { inQ = true; }
        else if (c === ',') { row.push(field.trim()); field = ""; }
        else if (c === '\n' || (c === '\r' && next === '\n')) {
          if (c === '\r') i++;
          row.push(field.trim()); field = "";
          if (row.some(f => f !== "")) rows.push(row);
          row = [];
        } else { field += c; }
      }
    }
    if (field !== "" || row.length) {
      row.push(field.trim());
      if (row.some(f => f !== "")) rows.push(row);
    }
    return rows;
  }

  // ── FIND COLUMN BY HEADER KEYWORD ──────────────────────────────────────────
  function findCol(headers, keywords) {
    const norm = headers.map(h => h.toLowerCase().trim());
    for (const kw of keywords) {
      const idx = norm.findIndex(h => h.includes(kw));
      if (idx >= 0) return idx;
    }
    return -1;
  }

  // ── RENDER ──────────────────────────────────────────────────────────────────
  function render(rows) {
    if (rows.length < 2) {
      document.getElementById("loading").style.display = "none";
      document.getElementById("error").style.display = "block";
      return;
    }

    const headers   = rows[0];
    const data      = rows.slice(1);
    const countryCol = findCol(headers, COUNTRY_KEYWORDS);
    const typeCol    = findCol(headers, TYPE_KEYWORDS);
    const statusCol  = findCol(headers, STATUS_KEYWORDS);

    // Header row
    const thead = document.getElementById("ec-head");
    const htr = document.createElement("tr");
    headers.forEach(h => {
      const th = document.createElement("th");
      th.textContent = h;
      htr.appendChild(th);
    });
    thead.appendChild(htr);

    // Data rows
    const tbody = document.getElementById("ec-body");
    data.forEach(cols => {
      const tr = document.createElement("tr");
      cols.forEach((val, i) => {
        const td = document.createElement("td");

        if (i === countryCol) {
          const f = getFlag(val);
          td.textContent = (f ? f + " " : "") + val;

        } else if (i === typeCol) {
          const badge = document.createElement("span");
          badge.className = "badge " + typeClass(val);
          badge.textContent = val;
          td.appendChild(badge);

        } else if (statusCol >= 0 && i === statusCol) {
          const s = document.createElement("span");
          s.className = statusClass(val);
          s.textContent = val;
          td.appendChild(s);

        } else {
          td.textContent = val;
        }

        tr.appendChild(td);
      });
      tbody.appendChild(tr);
    });

    document.getElementById("loading").style.display = "none";
    document.getElementById("table-wrap").style.display = "block";
  }

  // ── FETCH ───────────────────────────────────────────────────────────────────
  fetch(CSV_URL)
    .then(r => { if (!r.ok) throw new Error("HTTP " + r.status); return r.text(); })
    .then(text => render(parseCSV(text)))
    .catch(() => {
      document.getElementById("loading").style.display = "none";
      document.getElementById("error").style.display = "block";
    });
</script>
</body>
</html>
